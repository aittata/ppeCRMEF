# =========================================================================
# CONFIGURATION GENERALE DE L'APPLICATION (SCHOOL ABSENCES RESSOURCES)
# =========================================================================

# Type d'environnement (production / development)
NODE_ENV=production

# Port d'écoute de l'application (NestJS + Serveur statique Frontend combinés en Prod)
PORT=3000

# =========================================================================
# CONFIGURATION DE LA BASE DE DONNEES
# =========================================================================

# Type de base SQL utilisé: 'postgres' ou 'sqlite' (mettez 'sqlite' pour une installation sans docker)
DB_TYPE=postgres

# Indique si TypeORM doit automatiquement créer / synchroniser les tables au démarrage
DB_SYNC=true

# Paramètres de connexion PostgreSQL (Docker / Local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=password123
DB_DATABASE=school_absences

# Emplacement du fichier SQLite (uniquement si DB_TYPE=sqlite)
DB_SQLITE_PATH=./school.sqlite

# =========================================================================
# SECURITE & AUTHENTIFICATION (JWT)
# Précautions : Pour la production, générez des clés longues et aléatoires d'au moins 32 caractères.
# =========================================================================
JWT_SECRET=super-secret-jwt-min-32-chars-change-in-prod-12345
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-min-32-chars-change-in-prod-12345
JWT_REFRESH_EXPIRES_IN=7d

# =========================================================================
# LIMITATION DE DEBIT (RATE LIMITING)
# =========================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
