NODE_ENV=development
PORT=2999

# Database Configuration (Postgres vs SQLite)
DB_TYPE=postgres
DB_SYNC=true
DB_SQLITE_PATH=./school.sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=password123
DB_DATABASE=school_absences
JWT_SECRET=super-secret-jwt-min-32-chars-change-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-min-32-chars-change-in-prod
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
